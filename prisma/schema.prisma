generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum CommentTargetType {
  POST
  CASE
  GUESTBOOK
}

enum CommentStatus {
  VISIBLE
  HIDDEN
}

enum TrendPeriod {
  DAILY
  WEEKLY
}

enum SummaryStatus {
  GENERATED
  EDITED
  FAILED
}

model Post {
  id             String            @id @default(cuid())
  title          String
  slug           String            @unique
  summary        String
  coverImage     String?
  contentHtml    String            @db.Text
  status         ContentStatus     @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  categoryId     String?
  category       PostCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags           PostTagRelation[]
  comments       Comment[]
}

model PostCategory {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  posts Post[]
}

model PostTag {
  id    String            @id @default(cuid())
  name  String
  slug  String            @unique
  posts PostTagRelation[]
}

model PostTagRelation {
  postId String
  tagId  String
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    PostTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model CaseStudy {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  summary        String
  coverImage     String?
  contentHtml    String         @db.Text
  gallery        String[]
  techStack      String[]
  projectUrl     String?
  repoUrl        String?
  featured       Boolean        @default(false)
  status         ContentStatus  @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  comments       Comment[]
}

model Comment {
  id         String            @id @default(cuid())
  targetType CommentTargetType
  targetId   String
  nickname   String
  content    String
  status     CommentStatus     @default(VISIBLE)
  ipHash     String
  uaHash     String
  createdAt  DateTime          @default(now())
  post       Post?             @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId     String?
  caseStudy  CaseStudy?        @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)
  caseStudyId String?

  @@index([targetType, targetId, createdAt])
}

model GitHubTrendingSnapshot {
  id            String                  @id @default(cuid())
  sourceDate    DateTime
  period        TrendPeriod
  language      String?
  fetchedAt     DateTime                @default(now())
  rawPayload    Json
  repos         GitHubTrendingRepo[]
  summaries     GitHubTrendingSummary[]

  @@index([sourceDate, period, language])
}

model GitHubTrendingRepo {
  id             String                  @id @default(cuid())
  snapshotId     String
  repoFullName   String
  owner          String
  repoName       String
  description    String?
  language       String?
  starsTotal     Int?
  forks          Int?
  starsGained    Int?
  rank           Int
  keywords       String[]
  snapshot       GitHubTrendingSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, rank])
}

model GitHubTrendingSummary {
  id                   String                  @id @default(cuid())
  snapshotId           String
  summarySourcePayload Json
  aiSummary            String?                 @db.Text
  editedSummary        String?                 @db.Text
  status               SummaryStatus           @default(GENERATED)
  modelName            String?
  generatedAt          DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  snapshot             GitHubTrendingSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId])
}

model JobRun {
  id           String   @id @default(cuid())
  jobName      String
  status       String
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  durationMs   Int?
  errorMessage String?
}

model SiteSetting {
  id            String   @id @default(cuid())
  heroTitle     String
  heroIntro     String   @db.Text
  aboutHtml     String   @db.Text
  socialLinks   Json
  seoDefaults   Json
  commentsEnabled Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MediaAsset {
  id          String   @id @default(cuid())
  fileName    String
  mimeType    String
  storagePath String
  createdAt   DateTime @default(now())
}
